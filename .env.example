# Shared database. The agents library owns this schema; the backend reads it.
# With docker-compose up, use the MySQL URL. Without it, leave unset to fall
# back to a local SQLite file (./gov_oracle.db) for quick demos.
DATABASE_URL=mysql+pymysql://gov_oracle:gov_oracle@127.0.0.1:3306/gov_oracle

# Redis (queueing + report cache). Optional: backend degrades gracefully.
REDIS_URL=redis://127.0.0.1:6379/0

# LLM provider (OpenAI-compatible). Optional: when unset, the pipeline uses
# a deterministic rule-based analyst so everything still runs end to end.
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Crawler
CRAWL_TIMEOUT_SECONDS=20
CRAWL_MAX_SOURCES=100
CRAWL_USER_AGENT=GovOracleBot/0.1 (+https://github.com/gov-oracle; public-information audit)
# Deep crawl: follow top civically-scored links from each source page.
CRAWL_DEPTH=1
CRAWL_MAX_LINKS_PER_SOURCE=5
CRAWL_MAX_PAGES_TOTAL=80
# Headless-browser rescue for bot-walled/JS-only sites (needs playwright + chromium).
CRAWL_USE_BROWSER=true

# Flask backend
FLASK_PORT=5001
SCHEDULER_ENABLED=false
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5001/api
